{
  "rules": {
    "admin": {
      ".read": true,
      ".write": true
    },
    "students": {
      "$roll": {
        ".read": "auth != null && auth.uid == $roll",
        ".write": "auth != null && auth.uid == $roll"
      }
    },
    "buses": {
      ".read": true,
      ".write": "root.child('admin').child(auth.uid).exists() || root.child('drivers').child(auth.uid).exists()",
      "$busId": {
        ".write": "root.child('admin').child(auth.uid).exists() || root.child('drivers').child(auth.uid).exists()"
      }
    },
    "devices": {
      ".read": "root.child('admin').child(auth.uid).exists()",
      ".write": "root.child('drivers').child(auth.uid).exists()"
    },
    "positions": {
      ".read": "root.child('admin').child(auth.uid).exists() || root.child('students').child(auth.uid).exists()",
      ".write": "root.child('drivers').child(auth.uid).exists()"
    },
    "fees": {
      "$roll": {
        ".read": "auth != null && auth.uid == $roll",
        ".write": "root.child('admin').child(auth.uid).exists()"
      }
    },
    "attendance": {
      "$roll": {
        ".read": "auth != null && auth.uid == $roll",
        ".write": "auth != null"
      }
    },
    "busTokens": {
      ".read": "auth != null",
      "$busId": {
        ".write": "root.child('drivers').child(auth.uid).exists()"
      }
    },
    "studentNotifications": {
      "$roll": {
        ".read": "auth != null && auth.uid == $roll",
        ".write": "root.child('admin').child(auth.uid).exists()"
      }
    },
    "busNotifications": {
      "$busId": {
        ".read": "auth != null",
        ".write": "root.child('admin').child(auth.uid).exists()"
      }
    },
    "driverCalls": {
      "$busId": {
        ".read": "root.child('admin').child(auth.uid).exists() || root.child('drivers').child(auth.uid).exists()",
        ".write": "auth != null"
      }
    },
    "alerts": {
      "$busId": {
        ".read": "root.child('admin').child(auth.uid).exists() || root.child('drivers').child(auth.uid).exists()",
        ".write": "auth != null"
      }
    },
    "studentLocations": {
      "$busId": {
        ".read": "root.child('admin').child(auth.uid).exists() || root.child('drivers').child(auth.uid).exists()",
        ".write": "auth != null"
      }
    },
    "busAttendance": {
      "$busId": {
        ".read": "root.child('admin').child(auth.uid).exists() || root.child('drivers').child(auth.uid).exists()",
        ".write": "auth != null"
      }
    },
    ".read": false,
    ".write": false
  }
}
